---
import Base from '../../layouts/Base.astro';

// 진짜 피아노 배열 88키 (A0~C8, MIDI 21~108). 흰 건반 52 + 검은 건반 36.
// 각 건반은 진짜 버튼이라 손가락·키보드·보조기기로 누를 수 있어요.
const KO = ['도', '도♯', '레', '레♯', '미', '파', '파♯', '솔', '솔♯', '라', '라♯', '시'];
const isBlack = (pc: number) =>
  pc === 1 || pc === 3 || pc === 6 || pc === 8 || pc === 10;

// 진짜 피아노 물리 기하: 건반 뒤쪽에서 옥타브를 12등분(검은건반 폭 = 옥타브/12),
// 검은 건반은 반음 슬롯(1·3·6·8·10)에 위치 → 흰 건반 머리가 모두 균등(7/12 흰폭).
// 검은건반 중심 = 흰경계 + 아래 오프셋(흰 건반 폭 단위, + = 오른쪽). 12등분 모델 정확값.
const BLACK_OFF: Record<number, number> = {
  1: -0.125, // 도♯ (슬롯1 중심 0.875 − 경계 1.0)
  3: 0.042, // 레♯ (슬롯3 중심 2.0417 − 경계 2.0)
  6: -0.208, // 파♯ (슬롯6 중심 3.7917 − 경계 4.0)
  8: -0.042, // 솔♯ (슬롯8 중심 4.9583 − 경계 5.0)
  10: 0.125, // 라♯ (슬롯10 중심 6.125 − 경계 6.0)
};

type White = { midi: number; ko: string; oct: number; isC: boolean; i: number };
type Black = { midi: number; ko: string; oct: number; x: number; off: number };
const whites: White[] = [];
const blacks: Black[] = [];
let wc = 0; // 지금까지 흰 건반 수 = 다음 흰 건반의 인덱스(절대좌표용)
for (let midi = 21; midi <= 108; midi++) {
  const pc = midi % 12;
  const oct = Math.floor(midi / 12) - 1; // 과학적 음높이 표기(C4=가운데 도)
  if (isBlack(pc)) {
    blacks.push({ midi, ko: KO[pc], oct, x: wc, off: BLACK_OFF[pc] ?? 0 });
  } else {
    whites.push({ midi, ko: KO[pc], oct, isC: pc === 0, i: wc });
    wc++;
  }
}
---

<Base title="피아노 소리 들어보기">
  <main id="main">
    <a class="back" href="/"><span aria-hidden="true">←</span> 처음으로</a>

    <h1>피아노 소리 들어보기</h1>
    <p class="lead">건반을 누르면 피아노 소리가 나요.</p>
    <p class="lead note">
      소리가 안 나면, 폰 옆 볼륨 버튼을 올리고 무음(매너) 모드를 꺼 주세요.
    </p>

    <button id="play" class="big-button" type="button">
      <span aria-hidden="true">▶</span> 소리 들어보기
    </button>

    <p class="now" aria-live="polite"><span id="now">&nbsp;</span></p>

    <p class="hint">
      진짜 피아노처럼 건반 88개예요. 눌러서 치고, 끌어서 옮기고, 손가락 두 개로 키워요.
    </p>

    <div class="kb-bar" role="group" aria-label="건반 조절">
      <button class="kb-btn" id="zoomOut" type="button" aria-label="건반 작게">➖</button>
      <button class="kb-btn" id="zoomIn" type="button" aria-label="건반 크게">➕</button>
      <button class="kb-btn" id="recenter" type="button">가운데</button>
      <button class="kb-btn" id="fitAll" type="button">전체</button>
      <button class="kb-btn" id="lock" type="button" aria-pressed="false">🔓 자유</button>
    </div>

    <div class="piano-scroll" id="pianoScroll">
      <div class="keyboard" role="group" aria-label="피아노 건반 88개">
        <div class="whites">
          {
            whites.map((w) => (
              <button
                class="key wkey"
                type="button"
                data-midi={w.midi}
                aria-label={`${w.ko} ${w.oct}옥타브`}
                style={`left: calc(${w.i} * var(--wkw))`}
              >
                <span class="wlabel">{w.isC ? `도${w.oct}` : w.ko}</span>
              </button>
            ))
          }
        </div>
        <div class="blacks">
          {
            blacks.map((b) => (
              <button
                class="key bkey"
                type="button"
                data-midi={b.midi}
                aria-label={`${b.ko} ${b.oct}옥타브`}
                style={`left: calc((${b.x} + ${b.off}) * var(--wkw) - var(--bkw) / 2)`}
              />
            ))
          }
        </div>
      </div>
    </div>
  </main>
</Base>

<style>
  .back {
    display: inline-block;
    font-size: 1rem;
    font-weight: 700;
    padding: 12px 14px;
    margin-left: -14px;
    margin-bottom: 8px;
    text-decoration: none;
  }
  .back:active {
    opacity: 0.6;
  }

  .lead {
    font-size: 1.2rem;
    margin-bottom: 14px;
  }
  .lead.note {
    font-size: 1rem;
    color: var(--ink-soft);
    margin-bottom: 22px;
  }

  .big-button {
    width: 100%;
    padding: 30px;
    font-size: 1.55rem;
    font-weight: 800;
    color: var(--accent-ink);
    background: var(--accent);
    border: none;
    border-radius: var(--radius);
    box-shadow: 0 7px 0 var(--accent-deep);
    transition:
      transform 0.06s ease,
      box-shadow 0.06s ease,
      background 0.06s ease;
  }
  .big-button:active {
    transform: translateY(7px);
    box-shadow: 0 0 0 var(--accent-deep);
    background: var(--accent-deep);
  }

  .now {
    min-height: 1.6em; /* 긴 텍스트(도미솔도)가 좁은 화면에서 넘쳐 힌트와 겹치지 않게 */
    margin: 18px 0 6px;
    text-align: center;
  }
  .now #now {
    display: inline-block;
    min-width: 1.6em;
    font-size: 1.4rem;
    line-height: 1.25;
    font-weight: 800;
    color: var(--accent);
  }
  .now #now.pop {
    animation: pop 0.3s ease;
  }
  @keyframes pop {
    0% {
      transform: scale(0.6);
      opacity: 0.3;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  .hint {
    font-size: 1rem;
    color: var(--ink-soft);
    text-align: center;
    margin: 0 0 12px;
  }

  /* ── 88키 피아노 (가로 스크롤) ── */
  .piano-scroll {
    --wkw: 40px; /* 흰 건반 슬롯 폭(간격 포함) */
    --gap: 1.72px; /* 흰 건반 사이 간격 = 폭×0.043 (실제 ≈1mm/23.5mm) */
    --wkh: 255px; /* 흰 건반 길이 = 폭×6.38 (실제 150/23.5) */
    --bkw: 23.4px; /* 검은 건반 폭(0.585·흰폭, 실제 13.7/23.5) */
    --bkh: 153px; /* 검은 건반 길이(0.60·흰길이, 실제 90/150) */
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    /* 화면 가장자리까지 꽉 차게(좌우 패딩 상쇄) */
    margin: 0 calc(-1 * clamp(18px, 5vw, 28px));
    padding: 4px clamp(18px, 5vw, 28px) 14px;
    touch-action: none; /* 제스처(탭=연주, 드래그=이동, 핀치=확대)를 직접 처리 */
  }

  /* ── 건반 조절 바 ── */
  .kb-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin-bottom: 10px;
  }
  /* 건반이 너무 작은 전체보기에선 계이름 숨김 */
  .piano-scroll.no-labels .wlabel {
    display: none;
  }
  .kb-btn {
    min-width: 52px;
    height: 48px;
    padding: 0 12px;
    font-size: 1rem;
    font-weight: 800;
    white-space: nowrap;
    color: var(--ink);
    background: var(--soft);
    border: 2px solid var(--line);
    border-radius: 12px;
    cursor: pointer;
  }
  .kb-btn:active {
    background: var(--accent);
    color: var(--accent-ink);
    border-color: var(--accent);
  }
  .kb-btn[aria-pressed='true'] {
    background: var(--accent);
    color: var(--accent-ink);
    border-color: var(--accent);
  }
  .keyboard {
    position: relative;
    height: var(--wkh);
    width: calc(52 * var(--wkw));
    user-select: none;
    background: #1c1c1c; /* 건반 틈 사이로 보이는 어두운 바닥(케이스) */
    border-radius: 3px;
  }
  .whites {
    position: relative;
    height: 100%;
  }
  .wkey {
    position: absolute;
    top: 0;
    /* 슬롯(i×wkw)에 배치하고 폭은 (슬롯−간격) → 실제 ~1mm 간격(어두운 바닥이 보임) */
    width: calc(var(--wkw) - var(--gap));
    height: 100%;
    box-sizing: border-box;
    background: linear-gradient(180deg, #fdfdfd 0%, #fbfbfb 82%, #ececec 100%);
    border-bottom: 4px solid #cdcdcd; /* 앞쪽 3D 턱 */
    border-radius: 0 0 5px 5px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 8px;
  }
  .wlabel {
    font-size: 0.72rem;
    font-weight: 700;
    color: #9aa0a8;
    pointer-events: none;
  }
  .wkey:active,
  .wkey.is-on {
    background: linear-gradient(180deg, var(--accent) 0%, var(--accent-deep) 100%);
    border-bottom-color: var(--accent-deep);
  }
  .wkey:active .wlabel,
  .wkey.is-on .wlabel {
    color: var(--accent-ink);
  }

  .blacks {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    pointer-events: none;
    z-index: 2;
  }
  .bkey {
    position: absolute;
    top: 0;
    width: var(--bkw);
    height: var(--bkh);
    background: linear-gradient(180deg, #565656 0%, #232323 55%, #050505 100%);
    border-radius: 0 0 4px 4px;
    pointer-events: auto;
    /* 입체 그림자 + 앞쪽 광택 하이라이트(진짜 검은 건반 느낌) */
    box-shadow:
      0 3px 4px rgba(0, 0, 0, 0.55),
      inset 0 -3px 3px rgba(255, 255, 255, 0.16),
      inset 0 0 0 1px #000;
  }
  .bkey:active,
  .bkey.is-on {
    background: linear-gradient(180deg, var(--accent) 0%, var(--accent-deep) 100%);
  }

  /* 키보드 포커스 또렷하게 */
  .key:focus-visible {
    outline: 4px solid var(--accent);
    outline-offset: -4px;
    z-index: 3;
  }
</style>

<script>
  // ── 진짜 피아노 = 현의 물리. 음원 샘플 없이 모달 물리 모델 엔진(AudioWorklet,
  //    /piano-worklet.js)이 현의 진동 모드를 샘플 단위로 계산. + 공간감(리버브).
  //    워크릿 미지원(아주 구형)에서는 가벼운 가산 합성으로 폴백. ──
  const AC = (window.AudioContext ||
    (window as any).webkitAudioContext) as typeof AudioContext;

  let ctx: AudioContext | null = null;
  let node: AudioWorkletNode | null = null;
  let fbComp: DynamicsCompressorNode | null = null;
  let mode: 'worklet' | 'fallback' | null = null;
  let initPromise: Promise<void> | null = null;

  const midiToFreq = (m: number) => 440 * Math.pow(2, (m - 69) / 12);
  const KO = ['도', '도♯', '레', '레♯', '미', '파', '파♯', '솔', '솔♯', '라', '라♯', '시'];
  const koOf = (m: number) => KO[((m % 12) + 12) % 12];

  // 임펄스 응답 생성(절차적, 음원 파일 없음): 사용자 트랙의 공간감(리버브) 근사.
  function makeReverbIR(
    c: AudioContext,
    seconds: number,
    decay: number,
    damp: number,
    preDelay: number
  ) {
    const rate = c.sampleRate;
    const len = Math.floor(rate * seconds);
    const pre = Math.floor(rate * preDelay);
    const ir = c.createBuffer(2, pre + len, rate);
    for (let ch = 0; ch < 2; ch++) {
      const d = ir.getChannelData(ch);
      let lp = 0;
      for (let i = 0; i < len; i++) {
        const env = Math.pow(1 - i / len, decay);
        const n = (Math.random() * 2 - 1) * env;
        lp += damp * (n - lp); // 1극 저역통과 → 고역 댐핑(어두운 잔향)
        d[pre + i] = lp;
      }
    }
    return ir;
  }

  function ensureEngine(): Promise<void> {
    if (initPromise) return initPromise;
    initPromise = (async () => {
      ctx = new AC();
      // ── 공간감(리버브) 버스: 소스 → dry + wet(컨볼루션) → 출력 ──
      const out = ctx.createGain();
      out.connect(ctx.destination);
      const busIn = ctx.createGain();
      const dry = ctx.createGain();
      dry.gain.value = 0.82;
      const wet = ctx.createGain();
      wet.gain.value = 0.22;
      const conv = ctx.createConvolver();
      conv.normalize = true;
      conv.buffer = makeReverbIR(ctx, 2.5, 2.4, 0.38, 0.02);
      busIn.connect(dry);
      dry.connect(out);
      busIn.connect(conv);
      conv.connect(wet);
      wet.connect(out);
      try {
        if (!ctx.audioWorklet) throw new Error('no audioWorklet');
        await ctx.audioWorklet.addModule('/piano-worklet.js');
        node = new AudioWorkletNode(ctx, 'piano-processor', {
          outputChannelCount: [2],
        });
        node.connect(busIn);
        mode = 'worklet';
      } catch {
        fbComp = ctx.createDynamicsCompressor();
        fbComp.threshold.value = -18;
        fbComp.ratio.value = 4;
        const g = ctx.createGain();
        g.gain.value = 0.6;
        fbComp.connect(g);
        g.connect(busIn);
        mode = 'fallback';
      }
    })();
    return initPromise;
  }

  function resume() {
    if (ctx && ctx.state === 'suspended') ctx.resume();
  }

  // 폴백(워크릿 미지원): 간단한 비조화 가산 음
  function fallbackNote(f0: number, vel: number, when: number) {
    const c = ctx as AudioContext;
    const bus = c.createGain();
    bus.gain.value = vel * 0.5;
    bus.connect(fbComp as DynamicsCompressorNode);
    const B = 0.0004 * Math.pow(f0 / 261.63, 1.0);
    for (let n = 1; n <= 10; n++) {
      const fn = n * f0 * Math.sqrt(1 + B * n * n);
      if (fn >= 0.45 * c.sampleRate) break;
      const osc = c.createOscillator();
      osc.type = 'sine';
      osc.frequency.value = fn;
      const g = c.createGain();
      const a = (Math.sin((n * Math.PI) / 8) / n) * 0.5;
      const tau = 1.2 / Math.sqrt(n);
      g.gain.setValueAtTime(0.0001, when);
      g.gain.linearRampToValueAtTime(Math.abs(a) + 0.0001, when + 0.003);
      g.gain.setTargetAtTime(0.0001, when + 0.01, tau);
      osc.connect(g);
      g.connect(bus);
      osc.start(when);
      osc.stop(when + 6);
    }
  }

  async function playMidi(midi: number, vel = 0.8, delay = 0) {
    await ensureEngine();
    resume();
    if (mode === 'worklet' && node) {
      if (delay > 0) {
        setTimeout(
          () => node!.port.postMessage({ type: 'noteOn', midi, vel }),
          delay * 1000
        );
      } else {
        node.port.postMessage({ type: 'noteOn', midi, vel });
      }
    } else if (ctx) {
      fallbackNote(midiToFreq(midi), vel, ctx.currentTime + 0.005 + delay);
    }
  }

  // ── 화면 반응 ──
  const nowEl = document.getElementById('now');
  const keyByMidi = new Map<number, HTMLButtonElement>();
  document.querySelectorAll<HTMLButtonElement>('.key').forEach((k) => {
    keyByMidi.set(Number(k.dataset.midi), k);
  });
  function litKey(el: Element | null | undefined) {
    if (!el) return;
    el.classList.add('is-on');
    setTimeout(() => el.classList.remove('is-on'), 260);
  }
  function showNow(text: string) {
    if (!nowEl) return;
    nowEl.textContent = text;
    nowEl.classList.remove('pop');
    void (nowEl as HTMLElement).offsetWidth;
    nowEl.classList.add('pop');
  }

  function press(midi: number, keyEl: Element | null) {
    litKey(keyEl);
    showNow('지금 소리: ' + koOf(midi));
    // 사람이 친 듯 매 타건 셈여림을 미세하게 달리(고정음색 = 가짜 신호)
    playMidi(midi, 0.72 + Math.random() * 0.16);
  }

  // 큰 버튼: 도-미-솔-높은도 또르르 (해당 건반도 차례로 빛남)
  const melody = [60, 64, 67, 72];
  const STEP = 0.5;
  let playing = false;
  document.getElementById('play')?.addEventListener('click', () => {
    if (playing) return;
    playing = true;
    melody.forEach((m, i) => {
      playMidi(m, 0.85, i * STEP);
      setTimeout(() => litKey(keyByMidi.get(m)), i * STEP * 1000);
    });
    setTimeout(() => showNow('지금 소리: 도미솔도'), melody.length * STEP * 1000);
    setTimeout(
      () => {
        playing = false;
      },
      melody.length * STEP * 1000 + 1500
    );
  });

  // ── 건반 UX: 확대/축소(핀치·버튼·휠) · 이동(드래그·휠) · 탭=연주 · 고정(잠금) ──
  const scroller = document.getElementById('pianoScroll') as HTMLElement;
  let wkw = 40; // 흰 건반 폭(px)
  const MINW = 6, // 전체보기(88키 한 화면)까지 허용
    MAXW = 88;
  const ASPECT = 6.38; // 실제 흰 건반 길이:폭 (150/23.5)
  const GAP = 0.043; // 실제 흰 건반 사이 간격:폭 (≈1mm/23.5mm)
  function applyWkw() {
    const wkh = Math.min(340, Math.round(wkw * ASPECT)); // 폭에 비례(비율 유지), 과도하면 캡
    scroller.style.setProperty('--wkw', wkw + 'px');
    scroller.style.setProperty('--gap', (wkw * GAP).toFixed(2) + 'px'); // 실제 간격 비율
    scroller.style.setProperty('--bkw', (wkw * 0.585).toFixed(2) + 'px'); // 실제 흑/백 폭비 13.7/23.5
    scroller.style.setProperty('--wkh', wkh + 'px');
    scroller.style.setProperty('--bkh', Math.round(wkh * 0.6) + 'px'); // 실제 흑/백 길이비 90/150
    scroller.classList.toggle('no-labels', wkw < 22); // 작으면 계이름 숨김
  }
  // 기준점(화면상 X)을 고정한 채 확대/축소
  function setZoom(newW: number, anchorClientX?: number) {
    newW = Math.max(MINW, Math.min(MAXW, newW));
    const rect = scroller.getBoundingClientRect();
    const ax = anchorClientX == null ? rect.width / 2 : anchorClientX - rect.left;
    const contentX = scroller.scrollLeft + ax;
    const ratio = newW / wkw;
    wkw = newW;
    applyWkw();
    scroller.scrollLeft = contentX * ratio - ax;
  }
  function recenter(midi = 60) {
    const el = keyByMidi.get(midi);
    if (el)
      scroller.scrollLeft =
        el.offsetLeft - scroller.clientWidth / 2 + el.offsetWidth / 2;
  }

  let locked = false;
  const lockBtn = document.getElementById('lock') as HTMLButtonElement;
  lockBtn.addEventListener('click', () => {
    locked = !locked;
    lockBtn.setAttribute('aria-pressed', String(locked));
    lockBtn.textContent = locked ? '🔒 고정' : '🔓 자유';
  });
  document
    .getElementById('zoomIn')!
    .addEventListener('click', () => setZoom(wkw * 1.25));
  document
    .getElementById('zoomOut')!
    .addEventListener('click', () => setZoom(wkw / 1.25));
  document
    .getElementById('recenter')!
    .addEventListener('click', () => recenter(60));
  // 전체보기: 88키가 한 화면에 다 보이게(흰 건반 폭 = 화면÷52)
  document.getElementById('fitAll')!.addEventListener('click', () => {
    wkw = Math.max(MINW, Math.min(MAXW, scroller.clientWidth / 52));
    applyWkw();
    scroller.scrollLeft = 0;
  });

  // 포인터 제스처(마우스·터치 공통): 1손가락=탭연주/드래그이동, 2손가락=핀치확대
  const pts = new Map<number, { x: number; y: number }>();
  let drag: { x: number; scroll: number; key: Element | null; moved: boolean } | null =
    null;
  let pinch: { dist: number; w: number; cx: number } | null = null;
  const arr = () => [...pts.values()];
  const dist2 = () => {
    const a = arr();
    return Math.hypot(a[0].x - a[1].x, a[0].y - a[1].y);
  };
  const mid2 = () => {
    const a = arr();
    return (a[0].x + a[1].x) / 2;
  };

  scroller.addEventListener('pointerdown', (e) => {
    pts.set(e.pointerId, { x: e.clientX, y: e.clientY });
    if (pts.size === 2) {
      pinch = { dist: dist2(), w: wkw, cx: mid2() };
      drag = null;
      return;
    }
    drag = {
      x: e.clientX,
      scroll: scroller.scrollLeft,
      key: (e.target as Element).closest('.key'),
      moved: false,
    };
    try {
      scroller.setPointerCapture(e.pointerId);
    } catch {}
  });
  scroller.addEventListener('pointermove', (e) => {
    if (!pts.has(e.pointerId)) return;
    pts.set(e.pointerId, { x: e.clientX, y: e.clientY });
    if (pinch && pts.size >= 2) {
      const d = dist2();
      if (pinch.dist > 0) setZoom(pinch.w * (d / pinch.dist), pinch.cx);
      return;
    }
    if (drag) {
      const dx = e.clientX - drag.x;
      if (!drag.moved && Math.abs(dx) > 8) drag.moved = true;
      if (drag.moved && !locked) scroller.scrollLeft = drag.scroll - dx;
    }
  });
  function endPointer(e: PointerEvent) {
    if (drag && pts.size === 1 && !drag.moved && drag.key) {
      const midi = Number((drag.key as HTMLElement).dataset.midi);
      if (!Number.isNaN(midi)) press(midi, drag.key);
    }
    pts.delete(e.pointerId);
    if (pts.size < 2) pinch = null;
    if (pts.size === 0) drag = null;
  }
  scroller.addEventListener('pointerup', endPointer);
  scroller.addEventListener('pointercancel', endPointer);

  // 데스크탑 휠: 가로 스크롤 / Ctrl(⌘)+휠 = 확대축소
  scroller.addEventListener(
    'wheel',
    (e) => {
      e.preventDefault();
      if (e.ctrlKey || e.metaKey)
        setZoom(wkw * (e.deltaY < 0 ? 1.1 : 1 / 1.1), e.clientX);
      else scroller.scrollLeft += e.deltaX || e.deltaY;
    },
    { passive: false }
  );

  // 키보드 접근성: 포커스된 건반에서 Enter/Space로 연주
  document.querySelectorAll<HTMLButtonElement>('.key').forEach((key) => {
    key.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        const midi = Number(key.dataset.midi);
        if (!Number.isNaN(midi)) press(midi, key);
      }
    });
  });

  applyWkw();
  recenter(60);
</script>
