---
import Base from '../../layouts/Base.astro';

// 흰 건반 한 옥타브 (도~높은도). 각 건반은 진짜 버튼이라 손가락·키보드·보조기기로 누를 수 있어요.
// 어르신·초보 대상이라 반음(검은 건반)은 일부러 두지 않습니다.
// midi: 합성할 주파수를 계산하는 데 씁니다 (f = 440·2^((midi-69)/12)).
const whiteKeys = [
  { label: '도', midi: 60 }, // C4
  { label: '레', midi: 62 }, // D4
  { label: '미', midi: 64 }, // E4
  { label: '파', midi: 65 }, // F4
  { label: '솔', midi: 67 }, // G4
  { label: '라', midi: 69 }, // A4
  { label: '시', midi: 71 }, // B4
  { label: '도', midi: 72 }, // C5
];
---

<Base title="피아노 소리 들어보기">
  <main id="main">
    <a class="back" href="/"><span aria-hidden="true">←</span> 처음으로</a>

    <h1>피아노 소리 들어보기</h1>
    <p class="lead">버튼을 누르면 피아노 소리가 나요.</p>
    <p class="lead note">
      소리가 안 나면, 폰 옆 볼륨 버튼을 올리고 무음(매너) 모드를 꺼 주세요.
    </p>

    <button id="play" class="big-button" type="button">
      <span aria-hidden="true">▶</span> 소리 들어보기
    </button>

    <!-- 방금 난 음을 큰 글씨로 보여줘요 (소리 ↔ 화면 연결) -->
    <p class="now" aria-live="polite"><span id="now">&nbsp;</span></p>

    <p class="hint">
      건반을 하나씩 눌러도 소리가 나요. <span aria-hidden="true">↓</span>
    </p>

    <div class="piano" role="group" aria-label="피아노 건반">
      <div class="whites">
        {
          whiteKeys.map((k, i) => (
            <button
              class="key key--white"
              type="button"
              data-midi={k.midi}
              data-label={k.label}
              data-index={i}
              aria-label={`${k.label} 건반`}
            >
              <span class="key__label">{k.label}</span>
            </button>
          ))
        }
      </div>
    </div>
  </main>
</Base>

<style>
  .back {
    display: inline-block;
    font-size: 1rem;
    font-weight: 700;
    /* 떨리는 손도 쉽게 누르도록 탭 영역을 넓게 */
    padding: 12px 14px;
    margin-left: -14px;
    margin-bottom: 8px;
    text-decoration: none;
  }
  .back:active {
    opacity: 0.6;
  }

  .lead {
    font-size: 1.2rem;
    margin-bottom: 14px;
  }
  .lead.note {
    font-size: 1rem;
    color: var(--ink-soft);
    margin-bottom: 22px;
  }

  /* ── 큰 버튼: 두껍고 눌리는 느낌 ── */
  .big-button {
    width: 100%;
    padding: 30px;
    font-size: 1.55rem;
    font-weight: 800;
    color: var(--accent-ink);
    background: var(--accent);
    border: none;
    border-radius: var(--radius);
    box-shadow: 0 7px 0 var(--accent-deep);
    transition:
      transform 0.06s ease,
      box-shadow 0.06s ease,
      background 0.06s ease;
  }
  .big-button:active {
    transform: translateY(7px);
    box-shadow: 0 0 0 var(--accent-deep);
    background: var(--accent-deep);
  }

  /* ── 방금 난 음 표시 ── */
  .now {
    height: 1.6em;
    margin: 18px 0 6px;
    text-align: center;
  }
  .now #now {
    display: inline-block;
    min-width: 1.6em;
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--accent);
  }
  .now #now.pop {
    animation: pop 0.3s ease;
  }
  @keyframes pop {
    0% {
      transform: scale(0.6);
      opacity: 0.3;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  .hint {
    font-size: 1rem;
    color: var(--ink-soft);
    text-align: center;
    margin: 0 0 14px;
  }

  /* ── 피아노 (흰 건반만) ── */
  .piano {
    touch-action: manipulation; /* 두 번 탭 확대 방지 → 연주감 좋음 */
    user-select: none;
  }

  .whites {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
  }

  .key {
    border: 3px solid var(--line);
    transition:
      transform 0.05s ease,
      background 0.05s ease;
  }

  .key--white {
    height: 230px;
    background: var(--paper);
    border-radius: 0 0 12px 12px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 18px;
    box-shadow: 0 5px 0 rgba(22, 22, 22, 0.14);
  }
  .key__label {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--ink);
  }
  /* 눌리거나 연주될 때: 파랗게 빛나고 살짝 들어감 */
  .key--white.is-on {
    background: var(--accent);
    transform: translateY(4px);
    box-shadow: 0 1px 0 rgba(22, 22, 22, 0.14);
  }
  .key--white.is-on .key__label {
    color: var(--accent-ink);
  }
</style>

<script>
  // ── 진짜 피아노는 결국 '주파수의 집합'이다 ──
  // 음원 샘플 없이 Web Audio만으로 그랜드 피아노 현의 물리를 직접 합성합니다.
  //  · 비조화성:  fₙ = n·f₀·√(1+B·n²)   (현이 뻣뻣해 배음이 정수배보다 살짝 위로)
  //  · 배음별 차등 감쇠: 고배음이 먼저 죽어 시간이 갈수록 어두워짐 (피아노다움의 절반)
  //  · 기본음 < 2배음:   오르간처럼 안 들리게
  //  · 현 맥놀이(디튠) + 해머 타격 노이즈 + FM 어택색
  // 가산 비조화(몸통) + FM 어택색 + 해머 노이즈 하이브리드. 구형 iOS Safari 호환.
  const AC = (window.AudioContext ||
    (window as any).webkitAudioContext) as typeof AudioContext;

  let ctx: AudioContext | null = null;
  let comp: DynamicsCompressorNode | null = null;
  let NOISE: AudioBuffer | null = null;
  const activeVoices: { bus: GainNode }[] = [];
  const MAX_VOICES = 16;
  const LOOKAHEAD = 0.005;

  function audio(): AudioContext {
    if (!ctx) {
      ctx = new AC();
      comp = ctx.createDynamicsCompressor();
      comp.threshold.value = -18;
      comp.ratio.value = 4;
      comp.attack.value = 0.003;
      comp.release.value = 0.25;
      const master = ctx.createGain();
      master.gain.value = 0.7;
      comp.connect(master);
      master.connect(ctx.destination);
      // 해머용 화이트노이즈 — 코드로 생성(음원 파일 아님), 한 번만.
      NOISE = ctx.createBuffer(1, Math.floor(ctx.sampleRate * 0.05), ctx.sampleRate);
      const d = NOISE.getChannelData(0);
      for (let i = 0; i < d.length; i++) d[i] = Math.random() * 2 - 1;
    }
    if (ctx.state === 'suspended') ctx.resume();
    return ctx;
  }

  // 배음별 최대 진폭 (n2가 최강 → 오르간 회피)
  const PEAK = [0, 0.85, 1.0, 0.75, 0.55, 0.42, 0.32, 0.24, 0.18, 0.13, 0.1, 0.07, 0.05];
  function inharmonicity(f0: number): number {
    return f0 < 300 ? 0.00035 : f0 < 420 ? 0.0005 : 0.0007;
  }

  function reapOldest() {
    const c = audio();
    while (activeVoices.length >= MAX_VOICES) {
      const v = activeVoices.shift();
      if (!v) break;
      try {
        v.bus.gain.setTargetAtTime(0.0001, c.currentTime, 0.05);
        setTimeout(() => {
          try {
            v.bus.disconnect();
          } catch {}
        }, 200);
      } catch {}
    }
  }

  // 한 음 합성.
  function pianoNote(f0: number, velocity = 0.8, when?: number) {
    const c = audio();
    const t0 = when ?? c.currentTime + LOOKAHEAD;
    reapOldest();

    const hi = f0 > 400;
    const N = hi ? 8 : 12;
    const B = inharmonicity(f0);
    const tau1 = hi ? 0.8 : 1.2; // 기본음 감쇠 시정수
    const tail = hi ? 3 : 7; // 오실레이터 유지 시간(여운)
    const atk = hi ? 0.001 : 0.003; // 1~3ms 빠른 어택
    const nyq = 0.45 * c.sampleRate;

    const bus = c.createGain();
    bus.gain.value = velocity / 2; // 동시발음 헤드룸
    bus.connect(comp as DynamicsCompressorNode);
    const stopAt = t0 + tail;

    // ── 가산 비조화 부분음 뱅크 ──
    for (let n = 1; n <= N; n++) {
      const fn = n * f0 * Math.sqrt(1 + B * n * n); // 비조화 stretch
      if (fn >= nyq) break; // 나이퀴스트 가드
      const a0 = (PEAK[n] || 0.04) * Math.exp(-n / (N * 0.8)) * 0.5;
      const tauN = tau1 / Math.sqrt(n); // 고배음 빠른 감쇠 → 어두워짐
      const detunes = n <= 3 ? [0.5 + 0.05 * n, -(0.5 + 0.05 * n)] : [0];
      for (const dt of detunes) {
        const osc = c.createOscillator();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(fn + dt, t0); // 절대 Hz 디튠 → 맥놀이
        const g = c.createGain();
        const a = a0 / detunes.length;
        g.gain.setValueAtTime(0.0001, t0);
        g.gain.linearRampToValueAtTime(a, t0 + atk);
        if (n <= 2) {
          // 2중 감쇠: 빠른 초기 강하 후 긴 꼬리
          g.gain.setTargetAtTime(a * 0.45, t0 + atk, 0.15);
          g.gain.setTargetAtTime(0.0001, t0 + 0.25, tauN);
        } else {
          g.gain.setTargetAtTime(0.0001, t0 + atk, tauN);
        }
        osc.connect(g);
        g.connect(bus);
        osc.start(t0);
        osc.stop(stopAt);
      }
    }

    // ── FM 어택 색 (인덱스 envelope으로 어택 수십ms에 가둬 DX7화 회피) ──
    const car = c.createOscillator();
    car.frequency.value = f0;
    const mod = c.createOscillator();
    mod.frequency.value = f0 * 2; // 정수비 1:2 (종소리 회피)
    const idx = c.createGain();
    const I = 1.5 + 1.5 * velocity;
    idx.gain.setValueAtTime(0.0001, t0);
    idx.gain.linearRampToValueAtTime(f0 * I, t0 + 0.002);
    idx.gain.setTargetAtTime(0.0001, t0 + 0.002, 0.08);
    mod.connect(idx);
    idx.connect(car.frequency); // AudioParam FM
    const cg = c.createGain();
    cg.gain.setValueAtTime(0.0001, t0);
    cg.gain.linearRampToValueAtTime(0.25 * velocity, t0 + atk);
    cg.gain.setTargetAtTime(0.0001, t0 + atk, 0.18);
    car.connect(cg);
    cg.connect(bus);
    car.start(t0);
    mod.start(t0);
    car.stop(t0 + 1.2);
    mod.stop(t0 + 1.2);

    // ── 해머 타격 트랜지언트 ──
    const src = c.createBufferSource();
    src.buffer = NOISE;
    const bp = c.createBiquadFilter();
    bp.type = 'bandpass';
    bp.frequency.value = Math.min(4000, f0 * 2.2);
    bp.Q.value = 0.9;
    const hg = c.createGain();
    hg.gain.setValueAtTime(0.12 * velocity, t0);
    hg.gain.setTargetAtTime(0.0001, t0, 0.006); // ~30ms 소멸
    src.connect(bp);
    bp.connect(hg);
    hg.connect(bus);
    src.start(t0);
    src.stop(t0 + 0.05);

    // ── 자동 정리 ──
    const voice = { bus };
    activeVoices.push(voice);
    setTimeout(
      () => {
        try {
          bus.disconnect();
        } catch {}
        const k = activeVoices.indexOf(voice);
        if (k >= 0) activeVoices.splice(k, 1);
      },
      (tail + 0.5) * 1000
    );
  }

  const midiToFreq = (m: number) => 440 * Math.pow(2, (m - 69) / 12);

  // ── 화면 반응 ──
  const nowEl = document.getElementById('now');
  function litKey(el: Element | null) {
    if (!el) return;
    el.classList.add('is-on');
    setTimeout(() => el.classList.remove('is-on'), 260);
  }
  function showNow(text: string) {
    if (!nowEl) return;
    nowEl.textContent = text;
    nowEl.classList.remove('pop');
    void (nowEl as HTMLElement).offsetWidth; // 애니메이션 재시작
    nowEl.classList.add('pop');
  }

  const whiteByIndex = [
    ...document.querySelectorAll<HTMLButtonElement>('.key--white'),
  ];

  function press(midi: number, keyEl: Element | null, label?: string) {
    litKey(keyEl);
    if (label) showNow('지금 소리: ' + label);
    pianoNote(midiToFreq(midi), 0.8);
  }

  // 큰 버튼: 도-미-솔-높은도 또르르 (해당 건반도 차례로 빛남)
  const melody = [
    { midi: 60, idx: 0 },
    { midi: 64, idx: 2 },
    { midi: 67, idx: 4 },
    { midi: 72, idx: 7 },
  ];
  const STEP = 0.45; // 음 간격(초)
  let playing = false; // 연주 중 재클릭 시 중첩 방지
  document.getElementById('play')?.addEventListener('click', () => {
    if (playing) return;
    playing = true;
    const c = audio();
    const t0 = c.currentTime + LOOKAHEAD;
    melody.forEach((m, i) => {
      pianoNote(midiToFreq(m.midi), 0.85, t0 + i * STEP);
      setTimeout(() => litKey(whiteByIndex[m.idx]), i * STEP * 1000);
    });
    setTimeout(() => showNow('지금 소리: 도미솔도'), melody.length * STEP * 1000);
    setTimeout(
      () => {
        playing = false;
      },
      melody.length * STEP * 1000 + 1500
    );
  });

  // 각 건반: click 하나로 마우스·터치·키보드(Enter/Space)·보조기기 모두 지원
  document.querySelectorAll<HTMLButtonElement>('.key').forEach((key) => {
    key.addEventListener('click', () => {
      const midi = Number(key.dataset.midi);
      if (!Number.isNaN(midi)) press(midi, key, key.dataset.label);
    });
  });
</script>
