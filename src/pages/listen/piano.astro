---
import Base from '../../layouts/Base.astro';

// 흰 건반 한 옥타브 (도~높은도). 각 건반은 진짜 버튼이라 손가락·키보드·보조기기로 누를 수 있어요.
// 어르신·초보 대상이라 반음(검은 건반)은 일부러 두지 않습니다.
// midi: 물리 엔진이 현의 주파수를 계산하는 데 씁니다 (f = 440·2^((midi-69)/12)).
const whiteKeys = [
  { label: '도', midi: 60 }, // C4
  { label: '레', midi: 62 }, // D4
  { label: '미', midi: 64 }, // E4
  { label: '파', midi: 65 }, // F4
  { label: '솔', midi: 67 }, // G4
  { label: '라', midi: 69 }, // A4
  { label: '시', midi: 71 }, // B4
  { label: '도', midi: 72 }, // C5
];
---

<Base title="피아노 소리 들어보기">
  <main id="main">
    <a class="back" href="/"><span aria-hidden="true">←</span> 처음으로</a>

    <h1>피아노 소리 들어보기</h1>
    <p class="lead">버튼을 누르면 피아노 소리가 나요.</p>
    <p class="lead note">
      소리가 안 나면, 폰 옆 볼륨 버튼을 올리고 무음(매너) 모드를 꺼 주세요.
    </p>

    <button id="play" class="big-button" type="button">
      <span aria-hidden="true">▶</span> 소리 들어보기
    </button>

    <!-- 방금 난 음을 큰 글씨로 보여줘요 (소리 ↔ 화면 연결) -->
    <p class="now" aria-live="polite"><span id="now">&nbsp;</span></p>

    <p class="hint">
      건반을 하나씩 눌러도 소리가 나요. <span aria-hidden="true">↓</span>
    </p>

    <div class="piano" role="group" aria-label="피아노 건반">
      <div class="whites">
        {
          whiteKeys.map((k, i) => (
            <button
              class="key key--white"
              type="button"
              data-midi={k.midi}
              data-label={k.label}
              data-index={i}
              aria-label={`${k.label} 건반`}
            >
              <span class="key__label">{k.label}</span>
            </button>
          ))
        }
      </div>
    </div>
  </main>
</Base>

<style>
  .back {
    display: inline-block;
    font-size: 1rem;
    font-weight: 700;
    /* 떨리는 손도 쉽게 누르도록 탭 영역을 넓게 */
    padding: 12px 14px;
    margin-left: -14px;
    margin-bottom: 8px;
    text-decoration: none;
  }
  .back:active {
    opacity: 0.6;
  }

  .lead {
    font-size: 1.2rem;
    margin-bottom: 14px;
  }
  .lead.note {
    font-size: 1rem;
    color: var(--ink-soft);
    margin-bottom: 22px;
  }

  /* ── 큰 버튼: 두껍고 눌리는 느낌 ── */
  .big-button {
    width: 100%;
    padding: 30px;
    font-size: 1.55rem;
    font-weight: 800;
    color: var(--accent-ink);
    background: var(--accent);
    border: none;
    border-radius: var(--radius);
    box-shadow: 0 7px 0 var(--accent-deep);
    transition:
      transform 0.06s ease,
      box-shadow 0.06s ease,
      background 0.06s ease;
  }
  .big-button:active {
    transform: translateY(7px);
    box-shadow: 0 0 0 var(--accent-deep);
    background: var(--accent-deep);
  }

  /* ── 방금 난 음 표시 ── */
  .now {
    height: 1.6em;
    margin: 18px 0 6px;
    text-align: center;
  }
  .now #now {
    display: inline-block;
    min-width: 1.6em;
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--accent);
  }
  .now #now.pop {
    animation: pop 0.3s ease;
  }
  @keyframes pop {
    0% {
      transform: scale(0.6);
      opacity: 0.3;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  .hint {
    font-size: 1rem;
    color: var(--ink-soft);
    text-align: center;
    margin: 0 0 14px;
  }

  /* ── 피아노 (흰 건반만) ── */
  .piano {
    touch-action: manipulation; /* 두 번 탭 확대 방지 → 연주감 좋음 */
    user-select: none;
  }

  .whites {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
  }

  .key {
    border: 3px solid var(--line);
    transition:
      transform 0.05s ease,
      background 0.05s ease;
  }

  .key--white {
    height: 230px;
    background: var(--paper);
    border-radius: 0 0 12px 12px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 18px;
    box-shadow: 0 5px 0 rgba(22, 22, 22, 0.14);
  }
  .key__label {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--ink);
  }
  /* 눌리거나 연주될 때: 파랗게 빛나고 살짝 들어감 */
  .key--white.is-on {
    background: var(--accent);
    transform: translateY(4px);
    box-shadow: 0 1px 0 rgba(22, 22, 22, 0.14);
  }
  .key--white.is-on .key__label {
    color: var(--accent-ink);
  }
</style>

<script>
  // 진짜 피아노 = 현의 물리. 음원 샘플 없이, 모달 물리 모델 엔진(AudioWorklet,
  // /piano-worklet.js)이 현의 진동 모드를 샘플 단위로 계산해 소리를 만든다.
  // 워크릿을 못 쓰는 (아주 구형) 브라우저에서는 가벼운 가산 합성으로 폴백한다.
  const AC = (window.AudioContext ||
    (window as any).webkitAudioContext) as typeof AudioContext;

  let ctx: AudioContext | null = null;
  let node: AudioWorkletNode | null = null;
  let fbComp: DynamicsCompressorNode | null = null;
  let mode: 'worklet' | 'fallback' | null = null;
  let initPromise: Promise<void> | null = null;

  const midiToFreq = (m: number) => 440 * Math.pow(2, (m - 69) / 12);

  // 임펄스 응답 생성(절차적, 음원 파일 없음): 사용자 트랙의 공간감(리버브) 근사.
  // 지수 감쇠 노이즈 + 고역 댐핑(어두운 꼬리) + 짧은 프리딜레이, 좌우 디코릴레이션.
  function makeReverbIR(
    c: AudioContext,
    seconds: number,
    decay: number,
    damp: number,
    preDelay: number
  ) {
    const rate = c.sampleRate;
    const len = Math.floor(rate * seconds);
    const pre = Math.floor(rate * preDelay);
    const ir = c.createBuffer(2, pre + len, rate);
    for (let ch = 0; ch < 2; ch++) {
      const d = ir.getChannelData(ch);
      let lp = 0;
      for (let i = 0; i < len; i++) {
        const env = Math.pow(1 - i / len, decay);
        const n = (Math.random() * 2 - 1) * env;
        lp += damp * (n - lp); // 1극 저역통과 → 고역 댐핑(어두운 잔향)
        d[pre + i] = lp;
      }
    }
    return ir;
  }

  function ensureEngine(): Promise<void> {
    if (initPromise) return initPromise;
    initPromise = (async () => {
      ctx = new AC();
      // ── 공간감(리버브) 버스: 소스 → dry + wet(컨볼루션) → 출력 ──
      // 사용자 트랙의 잔향(측정 기반, 음악적으로 ~2.5초 방/홀)을 입혀 공간감을 맞춤.
      const out = ctx.createGain();
      out.connect(ctx.destination);
      const busIn = ctx.createGain();
      const dry = ctx.createGain();
      dry.gain.value = 0.82;
      const wet = ctx.createGain();
      wet.gain.value = 0.22;
      const conv = ctx.createConvolver();
      conv.normalize = true;
      conv.buffer = makeReverbIR(ctx, 2.5, 2.4, 0.38, 0.02);
      busIn.connect(dry);
      dry.connect(out);
      busIn.connect(conv);
      conv.connect(wet);
      wet.connect(out);
      try {
        if (!ctx.audioWorklet) throw new Error('no audioWorklet');
        await ctx.audioWorklet.addModule('/piano-worklet.js');
        node = new AudioWorkletNode(ctx, 'piano-processor', {
          outputChannelCount: [2],
        });
        node.connect(busIn);
        mode = 'worklet';
      } catch {
        // 폴백: 컴프레서 하나 두고 가벼운 가산 합성
        fbComp = ctx.createDynamicsCompressor();
        fbComp.threshold.value = -18;
        fbComp.ratio.value = 4;
        const g = ctx.createGain();
        g.gain.value = 0.6;
        fbComp.connect(g);
        g.connect(busIn);
        mode = 'fallback';
      }
    })();
    return initPromise;
  }

  function resume() {
    if (ctx && ctx.state === 'suspended') ctx.resume();
  }

  // ── 폴백(워크릿 미지원): 간단한 비조화 가산 음 ──
  function fallbackNote(f0: number, vel: number, when: number) {
    const c = ctx as AudioContext;
    const bus = c.createGain();
    bus.gain.value = vel * 0.5;
    bus.connect(fbComp as DynamicsCompressorNode);
    const B = 0.0004 * Math.pow(f0 / 261.63, 1.0);
    for (let n = 1; n <= 10; n++) {
      const fn = n * f0 * Math.sqrt(1 + B * n * n);
      if (fn >= 0.45 * c.sampleRate) break;
      const osc = c.createOscillator();
      osc.type = 'sine';
      osc.frequency.value = fn;
      const g = c.createGain();
      const a = (Math.sin((n * Math.PI) / 8) / n) * 0.5;
      const tau = 1.2 / Math.sqrt(n);
      g.gain.setValueAtTime(0.0001, when);
      g.gain.linearRampToValueAtTime(Math.abs(a) + 0.0001, when + 0.003);
      g.gain.setTargetAtTime(0.0001, when + 0.01, tau);
      osc.connect(g);
      g.connect(bus);
      osc.start(when);
      osc.stop(when + 6);
    }
  }

  async function playMidi(midi: number, vel = 0.8, delay = 0) {
    await ensureEngine();
    resume();
    if (mode === 'worklet' && node) {
      if (delay > 0) {
        setTimeout(() => node!.port.postMessage({ type: 'noteOn', midi, vel }), delay * 1000);
      } else {
        node.port.postMessage({ type: 'noteOn', midi, vel });
      }
    } else if (ctx) {
      fallbackNote(midiToFreq(midi), vel, ctx.currentTime + 0.005 + delay);
    }
  }

  // ── 화면 반응 ──
  const nowEl = document.getElementById('now');
  function litKey(el: Element | null) {
    if (!el) return;
    el.classList.add('is-on');
    setTimeout(() => el.classList.remove('is-on'), 260);
  }
  function showNow(text: string) {
    if (!nowEl) return;
    nowEl.textContent = text;
    nowEl.classList.remove('pop');
    void (nowEl as HTMLElement).offsetWidth; // 애니메이션 재시작
    nowEl.classList.add('pop');
  }

  const whiteByIndex = [
    ...document.querySelectorAll<HTMLButtonElement>('.key--white'),
  ];

  function press(midi: number, keyEl: Element | null, label?: string) {
    litKey(keyEl);
    if (label) showNow('지금 소리: ' + label);
    playMidi(midi, 0.8);
  }

  // 큰 버튼: 도-미-솔-높은도 또르르 (해당 건반도 차례로 빛남)
  const melody = [
    { midi: 60, idx: 0 },
    { midi: 64, idx: 2 },
    { midi: 67, idx: 4 },
    { midi: 72, idx: 7 },
  ];
  const STEP = 0.5; // 음 간격(초) — 피아노 여운에 맞춰 넉넉히
  let playing = false; // 연주 중 재클릭 시 중첩 방지
  document.getElementById('play')?.addEventListener('click', () => {
    if (playing) return;
    playing = true;
    melody.forEach((m, i) => {
      playMidi(m.midi, 0.85, i * STEP);
      setTimeout(() => litKey(whiteByIndex[m.idx]), i * STEP * 1000);
    });
    setTimeout(() => showNow('지금 소리: 도미솔도'), melody.length * STEP * 1000);
    setTimeout(
      () => {
        playing = false;
      },
      melody.length * STEP * 1000 + 1500
    );
  });

  // 각 건반: click 하나로 마우스·터치·키보드(Enter/Space)·보조기기 모두 지원
  document.querySelectorAll<HTMLButtonElement>('.key').forEach((key) => {
    key.addEventListener('click', () => {
      const midi = Number(key.dataset.midi);
      if (!Number.isNaN(midi)) press(midi, key, key.dataset.label);
    });
  });
</script>
