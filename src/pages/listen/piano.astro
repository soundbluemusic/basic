---
import Base from '../../layouts/Base.astro';

// 흰 건반 한 옥타브 (도~높은도). 각 건반은 진짜 버튼이라 손가락·키보드·보조기기로 누를 수 있어요.
// 어르신·초보 대상이라 반음(검은 건반)은 일부러 두지 않습니다.
// midi: 실제 피아노 샘플과 매핑해 음높이를 맞추는 데 씁니다.
const whiteKeys = [
  { label: '도', midi: 60 }, // C4
  { label: '레', midi: 62 }, // D4
  { label: '미', midi: 64 }, // E4
  { label: '파', midi: 65 }, // F4
  { label: '솔', midi: 67 }, // G4
  { label: '라', midi: 69 }, // A4
  { label: '시', midi: 71 }, // B4
  { label: '도', midi: 72 }, // C5
];
---

<Base title="피아노 소리 들어보기">
  <main id="main">
    <a class="back" href="/"><span aria-hidden="true">←</span> 처음으로</a>

    <h1>피아노 소리 들어보기</h1>
    <p class="lead">버튼을 누르면 피아노 소리가 나요.</p>
    <p class="lead note">
      소리가 안 나면, 폰 옆 볼륨 버튼을 올리고 무음(매너) 모드를 꺼 주세요.
    </p>

    <button id="play" class="big-button" type="button">
      <span aria-hidden="true">▶</span> 소리 들어보기
    </button>

    <!-- 방금 난 음을 큰 글씨로 보여줘요 (소리 ↔ 화면 연결) -->
    <p class="now" aria-live="polite"><span id="now">&nbsp;</span></p>

    <p class="hint">
      건반을 하나씩 눌러도 소리가 나요. <span aria-hidden="true">↓</span>
    </p>

    <div class="piano" role="group" aria-label="피아노 건반">
      <div class="whites">
        {
          whiteKeys.map((k, i) => (
            <button
              class="key key--white"
              type="button"
              data-midi={k.midi}
              data-label={k.label}
              data-index={i}
              aria-label={`${k.label} 건반`}
            >
              <span class="key__label">{k.label}</span>
            </button>
          ))
        }
      </div>
    </div>
  </main>
</Base>

<style>
  .back {
    display: inline-block;
    font-size: 1rem;
    font-weight: 700;
    /* 떨리는 손도 쉽게 누르도록 탭 영역을 넓게 */
    padding: 12px 14px;
    margin-left: -14px;
    margin-bottom: 8px;
    text-decoration: none;
  }
  .back:active {
    opacity: 0.6;
  }

  .lead {
    font-size: 1.2rem;
    margin-bottom: 14px;
  }
  .lead.note {
    font-size: 1rem;
    color: var(--ink-soft);
    margin-bottom: 22px;
  }

  /* ── 큰 버튼: 두껍고 눌리는 느낌 ── */
  .big-button {
    width: 100%;
    padding: 30px;
    font-size: 1.55rem;
    font-weight: 800;
    color: var(--accent-ink);
    background: var(--accent);
    border: none;
    border-radius: var(--radius);
    box-shadow: 0 7px 0 var(--accent-deep);
    transition:
      transform 0.06s ease,
      box-shadow 0.06s ease,
      background 0.06s ease;
  }
  .big-button:active {
    transform: translateY(7px);
    box-shadow: 0 0 0 var(--accent-deep);
    background: var(--accent-deep);
  }

  /* ── 방금 난 음 표시 ── */
  .now {
    height: 1.6em;
    margin: 18px 0 6px;
    text-align: center;
  }
  .now #now {
    display: inline-block;
    min-width: 1.6em;
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--accent);
  }
  .now #now.pop {
    animation: pop 0.3s ease;
  }
  @keyframes pop {
    0% {
      transform: scale(0.6);
      opacity: 0.3;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  .hint {
    font-size: 1rem;
    color: var(--ink-soft);
    text-align: center;
    margin: 0 0 14px;
  }

  /* ── 피아노 (흰 건반만) ── */
  .piano {
    touch-action: manipulation; /* 두 번 탭 확대 방지 → 연주감 좋음 */
    user-select: none;
  }

  .whites {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
  }

  .key {
    border: 3px solid var(--line);
    transition:
      transform 0.05s ease,
      background 0.05s ease;
  }

  .key--white {
    height: 230px;
    background: var(--paper);
    border-radius: 0 0 12px 12px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 18px;
    box-shadow: 0 5px 0 rgba(22, 22, 22, 0.14);
  }
  .key__label {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--ink);
  }
  /* 눌리거나 연주될 때: 파랗게 빛나고 살짝 들어감 */
  .key--white.is-on {
    background: var(--accent);
    transform: translateY(4px);
    box-shadow: 0 1px 0 rgba(22, 22, 22, 0.14);
  }
  .key--white.is-on .key__label {
    color: var(--accent-ink);
  }
</style>

<script>
  // 진짜 피아노 소리 — Salamander Grand Piano(야마하 C5) 녹음 샘플을 재생합니다.
  // 출처: Alexander Holm, CC-BY 3.0 (public/sounds/piano/, 자세한 건 CREDITS.md).
  // 옥타브 안 5개 지점(C4·D#4·F#4·A4·C5)만 받아두고, 각 건반은 가장 가까운
  // 샘플을 골라 최대 ±1반음만 미세 조정 → 음 깨짐 없이 피아노 음색 유지.
  const AC = (window.AudioContext ||
    (window as any).webkitAudioContext) as typeof AudioContext;
  let ctx: AudioContext | null = null;
  let master: GainNode | null = null;
  function audio(): AudioContext {
    if (!ctx) {
      ctx = new AC();
      master = ctx.createGain();
      master.gain.value = 0.9; // 여러 음이 겹쳐도 찢어지지 않게
      master.connect(ctx.destination);
    }
    if (ctx.state === 'suspended') ctx.resume();
    return ctx;
  }

  // 재생을 살짝 미리 잡아 첫 음이 잘리지 않게.
  const LOOKAHEAD = 0.05;

  // 받아둔 샘플 지점 (이름 → MIDI 번호)
  const SAMPLES = [
    { note: 'C4', midi: 60 },
    { note: 'Ds4', midi: 63 },
    { note: 'Fs4', midi: 66 },
    { note: 'A4', midi: 69 },
    { note: 'C5', midi: 72 },
  ];
  const url = (n: string) => `/sounds/piano/${n}.mp3`;

  function nearestSample(midi: number) {
    let best = SAMPLES[0];
    for (const s of SAMPLES) {
      if (Math.abs(s.midi - midi) < Math.abs(best.midi - midi)) best = s;
    }
    return best;
  }

  // 파일은 페이지가 뜨자마자 미리 내려받기 시작 (재생은 첫 탭 이후).
  const fetched: Record<string, Promise<ArrayBuffer>> = {};
  for (const s of SAMPLES) {
    fetched[s.note] = fetch(url(s.note)).then((r) => r.arrayBuffer());
  }

  // 구형 Safari는 콜백형 decodeAudioData만 지원 → 둘 다 받아줌.
  function decode(c: AudioContext, arr: ArrayBuffer): Promise<AudioBuffer> {
    return new Promise((res, rej) => {
      const p = c.decodeAudioData(arr, res, rej);
      if (p && typeof (p as any).then === 'function') (p as Promise<AudioBuffer>).then(res, rej);
    });
  }

  // 샘플 1개당 디코딩은 한 번만 (slice로 원본 보존).
  const decoding: Record<string, Promise<AudioBuffer>> = {};
  function getBuffer(note: string): Promise<AudioBuffer> {
    if (!decoding[note]) {
      decoding[note] = fetched[note].then((arr) => decode(audio(), arr.slice(0)));
    }
    return decoding[note];
  }

  function startNote(buf: AudioBuffer, midi: number, sampleMidi: number, when: number) {
    const c = audio();
    const src = c.createBufferSource();
    src.buffer = buf;
    src.playbackRate.value = Math.pow(2, (midi - sampleMidi) / 12);
    src.connect(master as GainNode);
    src.start(when);
  }

  // 화면 반응
  const nowEl = document.getElementById('now');
  function litKey(el: Element | null) {
    if (!el) return;
    el.classList.add('is-on');
    setTimeout(() => el.classList.remove('is-on'), 260);
  }
  function showNow(text: string) {
    if (!nowEl) return;
    nowEl.textContent = text;
    nowEl.classList.remove('pop');
    void (nowEl as HTMLElement).offsetWidth; // 애니메이션 재시작
    nowEl.classList.add('pop');
  }

  const whiteByIndex = [
    ...document.querySelectorAll<HTMLButtonElement>('.key--white'),
  ];

  async function press(midi: number, keyEl: Element | null, label?: string) {
    litKey(keyEl);
    if (label) showNow('지금 소리: ' + label);
    try {
      const s = nearestSample(midi);
      const buf = await getBuffer(s.note);
      startNote(buf, midi, s.midi, audio().currentTime + LOOKAHEAD);
    } catch {
      /* 네트워크 문제로 샘플을 못 받으면 조용히 넘어감 */
    }
  }

  // 큰 버튼: 도-미-솔-높은도 또르르 (해당 건반도 차례로 빛남)
  const melody = [
    { midi: 60, idx: 0 },
    { midi: 64, idx: 2 },
    { midi: 67, idx: 4 },
    { midi: 72, idx: 7 },
  ];
  const STEP = 0.45; // 음 간격(초) — 피아노 여운에 맞춰 넉넉히
  let playing = false; // 연주 중 재클릭 시 음 중첩 방지
  document.getElementById('play')?.addEventListener('click', async () => {
    if (playing) return;
    playing = true;
    try {
      const items = melody.map((m) => ({ ...m, s: nearestSample(m.midi) }));
      const bufs = await Promise.all(items.map((it) => getBuffer(it.s.note)));
      const t0 = audio().currentTime + LOOKAHEAD;
      items.forEach((it, i) => {
        startNote(bufs[i], it.midi, it.s.midi, t0 + i * STEP);
        setTimeout(() => litKey(whiteByIndex[it.idx]), i * STEP * 1000);
      });
      // 낭독기엔 음표마다가 아니라 끝에 한 번만 알림
      setTimeout(() => showNow('지금 소리: 도미솔도'), items.length * STEP * 1000);
      setTimeout(() => {
        playing = false;
      }, items.length * STEP * 1000 + 1500);
    } catch {
      playing = false;
    }
  });

  // 각 건반: click 하나로 마우스·터치·키보드(Enter/Space)·보조기기 모두 지원
  document.querySelectorAll<HTMLButtonElement>('.key').forEach((key) => {
    key.addEventListener('click', () => {
      const midi = Number(key.dataset.midi);
      if (!Number.isNaN(midi)) press(midi, key, key.dataset.label);
    });
  });
</script>
