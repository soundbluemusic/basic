---
// 모든 페이지가 쓰는 기본 껍데기.
// 어르신·왕초보 친화 규칙(큰 글씨, 흰 배경, 진한 글자, 한글 줄바꿈)을 여기서 한 번에 정합니다.
interface Props {
  title: string;
  description?: string;
}
const { title, description = '음악과 소리를, 세상에서 제일 쉽게.' } = Astro.props;

// 제목 접미사는 한 곳에서만 붙여 표기 흔들림을 막습니다.
const SUFFIX = 'basic';
const fullTitle = title && title !== SUFFIX ? `${title} — ${SUFFIX}` : SUFFIX;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta name="twitter:card" content="summary" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">본문 바로가기</a>
    <slot />
  </body>
</html>

<style is:global>
  /* ── 색 (색에만 의존하지 않도록 형태·글자도 함께 씀) ── */
  :root {
    --ink: #161616; /* 진한 검정 글자 */
    --ink-soft: #4a4a4a; /* 보조 글자 */
    --paper: #ffffff; /* 흰 배경 */
    --line: #161616; /* 테두리 */
    --accent: #0b57d0; /* 파랑 (링크/버튼) — 대비 충분 */
    --accent-deep: #08409c; /* 눌렀을 때 진한 파랑 */
    --accent-ink: #ffffff; /* 파랑 위 글자 */
    --soft: #f3f5f8; /* 아주 옅은 회색 카드 배경 */
    --space: 24px;
    --radius: 18px;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    /* 기본 글자 크게: 본문 26px */
    font-size: 26px;
    -webkit-text-size-adjust: 100%;
  }

  body {
    margin: 0 auto;
    max-width: 680px;
    padding: clamp(20px, 6vw, 36px) clamp(18px, 5vw, 28px) 80px;
    background: var(--paper);
    color: var(--ink);
    font-family: 'Apple SD Gothic Neo', 'Malgun Gothic', system-ui,
      -apple-system, sans-serif;
    line-height: 1.75;
    /* 한글: 단어(어절) 중간에서 줄을 끊지 않음 — 가독성 핵심 */
    word-break: keep-all;
    overflow-wrap: break-word;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  h1 {
    font-size: 1.9rem; /* ~49px */
    line-height: 1.25;
    font-weight: 800;
    margin: 0 0 16px;
  }

  p {
    font-size: 1rem; /* 26px */
    margin: 0 0 var(--space);
  }

  a {
    color: var(--accent);
  }

  /* ── 키보드로 이동할 때 또렷한 테두리 ── */
  a:focus-visible,
  button:focus-visible {
    outline: 5px solid var(--accent);
    outline-offset: 4px;
    border-radius: 6px;
  }

  /* 누를 수 있는 건 손가락 모양으로 */
  button {
    font-family: inherit;
    cursor: pointer;
  }

  /* 화면 낭독기 사용자용: 평소 숨겼다가 키보드 포커스 시 보임 */
  .skip-link {
    position: absolute;
    left: -9999px;
  }
  .skip-link:focus {
    position: static;
    display: inline-block;
    padding: 14px;
    font-weight: 700;
    background: var(--accent);
    color: var(--accent-ink);
    border-radius: 10px;
  }

  /* 화면 낭독기 전용 텍스트 */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  /* 움직임을 싫어하는 사용자 존중 */
  @media (prefers-reduced-motion: reduce) {
    * {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
